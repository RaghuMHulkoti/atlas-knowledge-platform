# ==============================================================================
# Atlas - Enterprise Engineering Knowledge Platform
# Example Environment Configuration
#
# Copy to `.env` and fill in the secrets. Only the two API keys are required;
# everything else has a working default.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

APP_NAME=Atlas
APP_VERSION=0.1.0
APP_DESCRIPTION=Enterprise Engineering Knowledge Platform

ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# LLM (OpenRouter)  — REQUIRED
#   Get a key at https://openrouter.ai/keys
#   Free models are rate-limited upstream; add your own credits / BYOK for
#   reliable throughput.
# ------------------------------------------------------------------------------

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODELS=openai/gpt-oss-120b:free,deepseek/deepseek-r1:free

# ------------------------------------------------------------------------------
# Embeddings
#   local  -> on-device HuggingFace model via sentence-transformers.
#             No API key required. Downloads the model once (bge-large ~1.3 GB).
#             Default: BAAI/bge-large-en-v1.5 (1024-dim).
#   google -> Google Generative AI embeddings. Requires GOOGLE_API_KEY and
#             GOOGLE_EMBEDDING_MODEL below.
#
#   NOTE: query and index embeddings must share a dimension. If you switch the
#   model or provider, delete/recreate the collection.
# ------------------------------------------------------------------------------

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:
# GOOGLE_EMBEDDING_MODEL=models/text-embedding-004
# GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------------------------
# Vector Store (Chroma Cloud)  — REQUIRED
#   Create a database at https://www.trychroma.com/
# ------------------------------------------------------------------------------

CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_chroma_tenant_id_here
CHROMA_DATABASE=your_chroma_database_name_here
CHROMA_PATH=./storage/chroma
DEFAULT_COLLECTION=atlas

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------

UPLOAD_DIRECTORY=./storage/uploads
REPOSITORY_DIRECTORY=./storage/repositories
MAX_UPLOAD_SIZE_MB=100

# ------------------------------------------------------------------------------
# Text Processing / Retrieval
# ------------------------------------------------------------------------------

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
