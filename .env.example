# ==============================================================================
# Atlas - Enterprise Engineering Knowledge Platform
# Example Environment Configuration
#
# Copy to `.env` and fill in the secrets. Only the two API keys are required;
# everything else has a working default.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

APP_NAME=Atlas
APP_VERSION=0.1.0
APP_DESCRIPTION=Enterprise Engineering Knowledge Platform

ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# LLM (OpenRouter)  — REQUIRED
#   Get a key at https://openrouter.ai/keys
#   Free models are rate-limited upstream; add your own credits / BYOK for
#   reliable throughput.
# ------------------------------------------------------------------------------

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODELS=openai/gpt-oss-120b:free,deepseek/deepseek-r1:free

# ------------------------------------------------------------------------------
# Embeddings — on-device ONNX MiniLM (all-MiniLM-L6-v2, 384-dim).
#   Free, no key, no quota, no rate limit. Downloads ~80 MB once.
# ------------------------------------------------------------------------------

EMBEDDING_PROVIDER=local

# Chunks are embedded in batches of this size. Smaller = lower peak memory
# (embedding a whole repo at once can OOM-kill a memory-limited container).
EMBEDDING_BATCH_SIZE=16

# ------------------------------------------------------------------------------
# Vector Store (Chroma Cloud)  — REQUIRED
#   Create a database at https://www.trychroma.com/
# ------------------------------------------------------------------------------

CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_chroma_tenant_id_here
CHROMA_DATABASE=your_chroma_database_name_here
CHROMA_PATH=./storage/chroma
DEFAULT_COLLECTION=atlas

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------

UPLOAD_DIRECTORY=./storage/uploads
REPOSITORY_DIRECTORY=./storage/repositories
MAX_UPLOAD_SIZE_MB=100

# ------------------------------------------------------------------------------
# Git authentication (optional — required only for PRIVATE repositories)
#   GitHub: create a personal access token at
#   https://github.com/settings/tokens (classic "repo" scope, or fine-grained
#   with "Contents: read"). Public repos need nothing here.
# ------------------------------------------------------------------------------

GIT_TOKEN=your_github_token_here
GIT_USERNAME=your_github_username_here

# ------------------------------------------------------------------------------
# Text Processing / Retrieval
# ------------------------------------------------------------------------------

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
