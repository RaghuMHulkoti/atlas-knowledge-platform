# ==============================================================================
# Atlas - Enterprise Engineering Knowledge Platform
# Example Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

APP_NAME=Atlas
APP_VERSION=0.1.0
APP_DESCRIPTION=Enterprise Engineering Knowledge Platform

ENVIRONMENT=development
DEBUG=true

# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------

API_V1_PREFIX=/api/v1

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Google Gemini
# ------------------------------------------------------------------------------

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------------------------
# ChromaDB
# ------------------------------------------------------------------------------

CHROMA_PATH=./storage/chroma
DEFAULT_COLLECTION=atlas

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------

UPLOAD_DIRECTORY=./storage/uploads
REPOSITORY_DIRECTORY=./storage/repositories

MAX_UPLOAD_SIZE_MB=100

# ------------------------------------------------------------------------------
# Text Processing
# ------------------------------------------------------------------------------

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ------------------------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------------------------

EMBEDDING_MODEL=models/text-embedding-004